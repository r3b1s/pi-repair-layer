{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2023"],
		"types": ["bun"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["index.ts", "src/**/*.ts", "test/**/*.ts"]
}
